@{
    ViewData["Title"] = "Registration Failed";
}

<div class="container mt-4">
    <div class="alert alert-danger">
        <h2>Registration Failed</h2>
        <p>There was a problem with your registration. Please try again.</p>
    </div>

    <a asp-controller="Account" asp-action="Register" class="btn btn-secondary">Back to Register</a>
</div>