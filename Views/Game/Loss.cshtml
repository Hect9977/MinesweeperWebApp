@{
    ViewData["Title"] = "Loss";
}

<style>
    .loss-page {
        text-align: center;
        padding: 40px 20px;
        position: relative;
        overflow: hidden;
        min-height: 80vh;
        background: linear-gradient(to bottom, #2c2c2c, #4b0000);
        color: white;
    }

    .loss-title {
        font-size: 3.5rem;
        font-weight: bold;
        color: #ff4d4d;
        text-shadow: 2px 2px 6px rgba(0, 0, 0, 0.4);
        margin-bottom: 20px;
    }

    .loss-message-box {
        display: inline-block;
        background-color: rgba(255, 255, 255, 0.1);
        border: 2px solid #ff4d4d;
        border-radius: 15px;
        padding: 20px 30px;
        margin-top: 15px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.25);
        font-size: 1.3rem;
        max-width: 700px;
        position: relative;
        z-index: 2;
    }

    .score-box {
        display: inline-block;
        background-color: white;
        border: 3px solid #ff4d4d;
        border-radius: 15px;
        padding: 20px 30px;
        margin-top: 20px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.25);
        font-size: 1.4rem;
        font-weight: bold;
        color: #4b0000;
        position: relative;
        z-index: 2;
    }

    .details-box {
        display: inline-block;
        background-color: white;
        border: 2px solid #ff4d4d;
        border-radius: 15px;
        padding: 15px 25px;
        margin-top: 20px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.25);
        font-size: 1.05rem;
        color: #4b0000;
        position: relative;
        z-index: 2;
        line-height: 1.8;
    }

    .try-again-btn {
        display: inline-block;
        margin-top: 25px;
        padding: 12px 24px;
        background-color: #ff4d4d;
        color: white;
        text-decoration: none;
        font-weight: bold;
        border-radius: 10px;
        position: relative;
        z-index: 2;
    }

        .try-again-btn:hover {
            background-color: #cc3333;
            color: white;
        }

    .bomb {
        position: absolute;
        top: -60px;
        font-size: 2rem;
        animation: floatDown linear infinite;
        opacity: 0.9;
    }

    .bomb1 {
        left: 5%;
        animation-duration: 4s;
    }

    .bomb2 {
        left: 12%;
        animation-duration: 5s;
    }

    .bomb3 {
        left: 20%;
        animation-duration: 3.5s;
    }

    .bomb4 {
        left: 28%;
        animation-duration: 4.8s;
    }

    .bomb5 {
        left: 36%;
        animation-duration: 5.5s;
    }

    .bomb6 {
        left: 44%;
        animation-duration: 4.2s;
    }

    .bomb7 {
        left: 52%;
        animation-duration: 3.8s;
    }

    .bomb8 {
        left: 60%;
        animation-duration: 5.2s;
    }

    .bomb9 {
        left: 68%;
        animation-duration: 4.4s;
    }

    .bomb10 {
        left: 76%;
        animation-duration: 3.9s;
    }

    .bomb11 {
        left: 84%;
        animation-duration: 5.1s;
    }

    .bomb12 {
        left: 92%;
        animation-duration: 4.3s;
    }

    @@keyframes floatDown {
        0% {
            transform: translateY(0) rotate(0deg);
        }

        100% {
            transform: translateY(100vh) rotate(-360deg);
        }
    }
</style>

<div class="loss-page">
    <div class="bomb bomb1">💣</div>
    <div class="bomb bomb2">💣</div>
    <div class="bomb bomb3">💣</div>
    <div class="bomb bomb4">💣</div>
    <div class="bomb bomb5">💣</div>
    <div class="bomb bomb6">💣</div>
    <div class="bomb bomb7">💣</div>
    <div class="bomb bomb8">💣</div>
    <div class="bomb bomb9">💣</div>
    <div class="bomb bomb10">💣</div>
    <div class="bomb bomb11">💣</div>
    <div class="bomb bomb12">💣</div>

    <h2 class="loss-title">GAME OVER</h2>

    <div class="loss-message-box">
        <p>@ViewBag.LossMessage</p>
    </div>

    @* Show the final game score after the player hits a mine. *@
    <div class="score-box">
        Final Score: @ViewBag.Score
    </div>

    @* Show the same game details used on the Winner page. *@
    <div class="details-box">
        Time: @ViewBag.Time seconds <br />
        Board Size: @ViewBag.BoardSize <br />
        Difficulty: @ViewBag.Difficulty
    </div>

    @* Give the player a quick way to start over after losing. *@
    <div>
        <a href="/Game/StartGame" class="try-again-btn">Try Again</a>
    </div>
</div>