@model MinesweeperWebApp.Models.Board

@{
    ViewData["Title"] = "MineSweeperBoard";
}

<link rel="stylesheet" href="~/css/minesweeper.css" />

<div class="board-page">
    <h2 class="board-title">Minesweeper Board</h2>

    <p class="board-subtitle">
        Click carefully and avoid the mines.
    </p>

    <div class="game-info-box">
        Player: @ViewBag.GameOwner |
        Board Size: @ViewBag.BoardSize x @ViewBag.BoardSize |
        Difficulty: @ViewBag.Difficulty |
        Time: <span id="gameTime">00:00</span> |
        Score: <span id="gameScore">@ViewBag.Score</span>
    </div>

    @*This section displays a success message if the game was saved successfully.*@
    @if (TempData["SaveMessage"] != null)
    {
        <div class="alert alert-success mt-3">
            @TempData["SaveMessage"]
        </div>
    }

    <form asp-controller="Game" asp-action="SaveGame" method="post" class="mb-3">
        <button type="submit" class="btn btn-primary">
            Save Game
        </button>
    </form>

    <a asp-controller="Game" asp-action="ShowSavedGames" class="btn btn-secondary mb-3">
        Show Saved Games
    </a>

    @* This builds the game board using the size of the board model. *@
    <div class="board-grid" style="grid-template-columns: repeat(@Model.Size, 60px);">
        @for (int row = 0; row < Model.Size; row++)
        {
            for (int col = 0; col < Model.Size; col++)
            {
                var cell = Model.Cells[row][col];

                @* Each button stores its row and column so JavaScript knows which cell was clicked. *@
                @* Milestone 3: Store the flag state on each button so left-click and right-click can work correctly. *@
                <button class="board-cell cell-button"
                        type="button"
                        data-row="@row"
                        data-col="@col"
                        data-flagged="@cell.IsFlagged.ToString().ToLower()">

                    @* Milestone 3: Show the flag image first if the cell is currently flagged. *@
                    @if (cell.IsFlagged)
                    {
                        <img src="~/img/flag.png" alt="Flag Tile" class="tile-img" />
                    }
                    else if (!cell.IsVisited)
                    {
                        <img src="~/img/hidden.png" alt="Hidden Tile" class="tile-img" />
                    }
                    else if (cell.HasMine)
                    {
                        <img src="~/img/mine.png" alt="Mine Tile" class="tile-img" />
                    }
                    else if (cell.LiveNeighbors > 0)
                    {
                        <img src="~/img/tile@(cell.LiveNeighbors).png" alt="Tile @cell.LiveNeighbors" class="tile-img" />
                    }
                    else
                    {
                        <img src="~/img/revealed.png" alt="Revealed Tile" class="tile-img" />
                    }
                </button>
            }
        }
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const cellButtons = document.querySelectorAll(".cell-button");
        const timeBox = document.getElementById("gameTime");

        // Milestone 3:
        // Get the start time from the controller so the timer can keep running live
        const startTimeString = "@ViewBag.StartTime";

        // Milestone 3:
        // This updates the timer on the page every second
        function updateLiveTimer() {
            if (!startTimeString || !timeBox) {
                return;
            }

            const startTime = new Date(startTimeString);
            const now = new Date();
            const elapsedMilliseconds = now - startTime;

            const totalSeconds = Math.floor(elapsedMilliseconds / 1000);
            const minutes = Math.floor(totalSeconds / 60).toString().padStart(2, '0');
            const seconds = (totalSeconds % 60).toString().padStart(2, '0');

            timeBox.textContent = `${minutes}:${seconds}`;
        }

        // Milestone 3:
        // Run the timer right away and keep it updating every second
        updateLiveTimer();
        setInterval(updateLiveTimer, 1000);

        // Milestone 3:
        // This updates every tile that changed after a move, including flood fill
        function updateChangedCells(changedCells) {
            if (!changedCells) {
                return;
            }

            changedCells.forEach(function (cell) {
                const button = document.querySelector(`.cell-button[data-row="${cell.row}"][data-col="${cell.col}"]`);

                if (button) {
                    const image = button.querySelector("img");
                    image.src = cell.imageUrl;
                    button.dataset.flagged = cell.isFlagged ? "true" : "false";
                }
            });
        }

        cellButtons.forEach(function (button) {
            button.addEventListener("click", function () {

                // Milestone 3:
                // Do not left-click a cell that is currently flagged
                if (this.dataset.flagged === "true") {
                    return;
                }

                const row = this.dataset.row;
                const col = this.dataset.col;

                fetch('/Game/LeftClick', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: `row=${row}&col=${col}`
                })
                .then(response => response.json())
                .then(data => {
                    if (!data.success) {
                        if (data.redirectUrl) {
                            window.location.href = data.redirectUrl;
                        }
                        return;
                    }

                    // Milestone 3:
                    // Update every changed tile after the move so flood fill shows correctly
                    updateChangedCells(data.changedCells);

                    const scoreBox = document.getElementById("gameScore");
                    if (scoreBox) {
                        scoreBox.textContent = data.score;
                    }

                    if (timeBox) {
                        timeBox.textContent = data.time;
                    }

                    if (data.isGameOver) {
                        setTimeout(function () {
                            window.location.href = data.lossUrl;
                        }, 1200);
                    }

                    if (data.isWin) {
                        window.location.href = data.winUrl;
                    }
                })
                .catch(error => {
                    console.log("Error updating cell:", error);
                });
            });

            // Milestone 3:
            // Handle right-click so the player can place or remove a flag
            button.addEventListener("contextmenu", function (event) {
                event.preventDefault();

                const row = this.dataset.row;
                const col = this.dataset.col;
                const clickedButton = this;

                fetch('/Game/RightClick', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: `row=${row}&col=${col}`
                })
                .then(response => response.json())
                .then(data => {
                    if (!data.success) {
                        if (data.redirectUrl) {
                            window.location.href = data.redirectUrl;
                        }
                        return;
                    }

                    const image = clickedButton.querySelector("img");
                    image.src = data.imageUrl;

                    // Milestone 3:
                    // Save the flag state on the button so left-click knows when to stop
                    clickedButton.dataset.flagged = data.isFlagged ? "true" : "false";

                    const scoreBox = document.getElementById("gameScore");
                    if (scoreBox) {
                        scoreBox.textContent = data.score;
                    }

                    if (timeBox) {
                        timeBox.textContent = data.time;
                    }

                    // Milestone 3:
                    // If the board is fully completed after placing or removing a flag, go to the win page
                    if (data.isWin) {
                        window.location.href = '/Game/Win';
                    }
                })
                .catch(error => {
                    console.log("Error updating flag:", error);
                });
            });
        });
    });
</script>